  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^22.15.17",
    "@types/turndown": "^5.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "mdast-util-mdx": "^3.0.0",
