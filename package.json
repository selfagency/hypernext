{
  "name": "@selfagency/hypernext",
  "version": "0.1.0",
  "description": "Multi-Protocol MDX Document Server",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "author": "Daniel Sieradski <daniel@self.agency>",
  "keywords": [
    "markdown",
    "md",
    "mdx",
    "html",
    "http",
    "gopher",
    "gemini",
    "rss",
    "spartan",
    "nex",
    "finger",
    "atproto",
    "activitypub",
    "textcasting"
  ],
  "main": "dist/index.js",
  "bin": {
    "hypernext": "dist/bin.js"
  },
  "scripts": {
    "dev": "tsx watch src/bin.ts",
    "build": "vite build",
    "start": "node dist/bin.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky",
    "docs": "vitepress dev docs"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm dlx ultracite fix"
    ]
  },
  "dependencies": {
    "@atproto/api": "^0.15.0",
    "@aws-sdk/client-s3": "^3.800.0",
    "@fastify/accepts": "^5.0.4",
