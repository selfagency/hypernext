    "@upyo/core": "^0.5.1",
    "@upyo/smtp": "^0.5.1",
    "better-sqlite3": "^12.11.1",
    "cac": "^6.7.14",
    "fastify": "^5.3.2",
    "fastify-405": "^4.0.0",
    "fastify-graceful-shutdown": "^5.0.0",
